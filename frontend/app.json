{
  "expo": {
    "name": "Gaon Delivery",
    "slug": "gaon-delivery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "gaondelivery",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.gaondelivery.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Find nearby shops and track delivery",
        "NSCameraUsageDescription": "Take photos for orders",
        "NSMicrophoneUsageDescription": "Use voice search to find products",
        "NSPhotoLibraryUsageDescription": "Select photos for shop listing"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.gaondelivery.app",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Gaon Delivery to use your location to find nearby shops and track deliveries."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Gaon Delivery to access your camera to take photos."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#ffffff"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}